# ============================================
# TonbilAiFirewall - Ortam Degiskenleri
# ============================================
# Bu dosyayi .env olarak kopyalayin ve degerlerini guncelleyin:
#   cp .env.example backend/.env

# --- Veritabani (MariaDB) ---
DATABASE_URL=mysql+aiomysql://tonbilai:SIFRENIZI_DEGISTIRIN@localhost:3306/tonbilaios

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Uygulama ---
ENVIRONMENT=production
# Asagidaki komutu calistirarak guvenli bir anahtar uretin:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=BURAYA_EN_AZ_32_KARAKTER_RASTGELE_ANAHTAR_YAZIN

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Guvenilir Proxy IP'leri ---
TRUSTED_PROXIES=172.16.0.0/12,10.0.0.0/8,192.168.0.0/16,127.0.0.1
